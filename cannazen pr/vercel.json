{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    }
  ],
  "regions": ["cdg1"],
  "installCommand": "echo 'No dependencies to install'",
  "buildCommand": "echo 'Static HTML - no build needed'",
  "devCommand": "echo 'Static HTML - no dev server needed'"
}